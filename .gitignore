## Terragrunt
# Working directory cache (created on every init/plan/apply)
.terragrunt-cache/

# Files generated by terragrunt.hcl generate{} blocks — recreated at runtime
backend.tf
versions.tf
provider.tf

## Terraform
# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform internals
.terraform/
# .terraform.lock.hcl  # uncomment to ignore; commit it to pin provider versions
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
!example.tfvars

## Operating System Specific
# macOS
.DS_Store

## Nix
.direnv/
.pre-commit-config.yaml

## Tools
.serena/
*local.json
